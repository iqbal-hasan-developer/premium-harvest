NEXT_PUBLIC_SITE_URL=https://premium-harvest.example.com
NEXT_PUBLIC_WHATSAPP_NUMBER=8801700000000

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Local development can use demo storefront data when Firebase Admin is not configured.
# Production should require Firebase Admin so the app fails clearly instead of using demo data.
# Vercel production already sets VERCEL_ENV=production, but keeping this explicit is recommended.
FIREBASE_ADMIN_REQUIRED=false
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_client_email

# Use one of these safe formats. Do not commit real secrets.
#
# Recommended for .env.local and Vercel:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_BODY\n-----END PRIVATE KEY-----\n"
#
# Also supported in local .env files if your tooling preserves multiline quoted values:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
# YOUR_KEY_BODY
# -----END PRIVATE KEY-----
# "
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_BODY\n-----END PRIVATE KEY-----\n"
