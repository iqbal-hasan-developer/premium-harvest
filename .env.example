NEXT_PUBLIC_SITE_URL=https://premium-harvest.example.com
NEXT_PUBLIC_WHATSAPP_NUMBER=8801700000000
NEXT_PUBLIC_META_PIXEL_ID=

# Supabase public values.
# NEXT_PUBLIC_SUPABASE_ANON_KEY is safe for browser use when Row Level Security is enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PRODUCTS_BUCKET=products
NEXT_PUBLIC_SUPABASE_GALLERY_BUCKET=gallery
NEXT_PUBLIC_SUPABASE_BANNERS_BUCKET=banners

# Supabase server-only value.
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS and must never be exposed in client code or public bundles.
# Do not paste real secrets into GitHub.
SUPABASE_SERVICE_ROLE_KEY=

# Optional local preview fallback only. Production should leave this false.
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
